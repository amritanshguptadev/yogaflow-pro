---
import B12Link from './B12Link.astro';
---

<footer class="bg-primary/5 border-t border-border mt-20">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8 mb-8">
      <div>
        <div class="flex items-center gap-2 mb-4">
          <div class="w-10 h-10 bg-gradient-to-br from-primary to-accent rounded-lg flex items-center justify-center">
            <span class="text-white font-bold text-lg">ʎ</span>
          </div>
          <span class="font-heading font-semibold text-foreground">YogaFlow Pro</span>
        </div>
        <p class="text-muted-foreground text-sm">
          An innovative web application designed to create a seamless and intelligent yoga session booking experience.
        </p>
      </div>

      <div>
        <h4 class="font-heading font-semibold text-foreground mb-4">Platform</h4>
        <ul class="space-y-2 text-sm">
          <li><a href="/#services" class="text-muted-foreground hover:text-primary transition-colors">Services</a></li>
          <li><a href="/#scheduling" class="text-muted-foreground hover:text-primary transition-colors">Scheduling</a></li>
          <li><a href="/#how-it-works" class="text-muted-foreground hover:text-primary transition-colors">How It Works</a></li>
        </ul>
      </div>

      <div>
        <h4 class="font-heading font-semibold text-foreground mb-4">Community</h4>
        <ul class="space-y-2 text-sm">
          <li><a href="/#blog" class="text-muted-foreground hover:text-primary transition-colors">Blog</a></li>
          <li><a href="/#testimonials" class="text-muted-foreground hover:text-primary transition-colors">Testimonials</a></li>
          <li><a href="/#team" class="text-muted-foreground hover:text-primary transition-colors">Team</a></li>
        </ul>
      </div>

      <div>
        <h4 class="font-heading font-semibold text-foreground mb-4">Contact</h4>
        <ul class="space-y-2 text-sm">
          <li><a href="/privacy-policy" class="text-muted-foreground hover:text-primary transition-colors">Privacy Policy</a></li>
          <li><a href="/contact" class="text-muted-foreground hover:text-primary transition-colors">Contact Us</a></li>
          <li><a href="mailto:support@yogaflowpro.com" class="text-muted-foreground hover:text-primary transition-colors">support@yogaflowpro.com</a></li>
          <li><a href="tel:+919856472589" class="text-muted-foreground hover:text-primary transition-colors">+91 9856472589</a></li>
          <li><a href="tel:+917569874626" class="text-muted-foreground hover:text-primary transition-colors">+91 7569874626</a></li>
        </ul>
      </div>
    </div>

    <div class="border-t border-border pt-8 flex flex-col sm:flex-row items-center justify-between">
      <p class="text-muted-foreground text-sm">
        &copy; 2026 YogaFlow Pro. All rights reserved.
      </p>
      <B12Link />
    </div>
  </div>
</footer>
