---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import RequiredB12HeadScripts from '../components/RequiredB12HeadScripts.astro';
import RequiredB12FooterScripts from '../components/RequiredB12FooterScripts.astro';
import ClassBrowser from '../components/ClassBrowser.tsx';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>Browse Classes - YogaFlow Pro</title>
    <meta name="description" content="Browse and book yoga classes that match your preferences, schedule, and goals." />
    <RequiredB12HeadScripts />
  </head>

  <body>
    <Header currentPage="/browse-classes" />

    <main>
      <!-- Page Header -->
      <section class="py-12 sm:py-16 bg-gradient-to-br from-secondary via-background to-accent/10">
        <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
          <h1 class="text-4xl sm:text-5xl md:text-6xl font-heading font-bold text-foreground mb-2 sm:mb-4">
            Browse Classes
          </h1>
          <p class="text-base sm:text-lg text-muted-foreground">
            Find the perfect yoga class tailored to your preferences and schedule
          </p>
        </div>
      </section>

      <!-- Class Browser Component -->
      <section class="py-12 sm:py-20 bg-background">
        <ClassBrowser client:load />
      </section>
    </main>

    <Footer />
    <RequiredB12FooterScripts />
  </body>
</html>
