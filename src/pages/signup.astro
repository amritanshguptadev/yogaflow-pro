---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import RequiredB12HeadScripts from '../components/RequiredB12HeadScripts.astro';
import RequiredB12FooterScripts from '../components/RequiredB12FooterScripts.astro';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>Sign Up - YogaFlow Pro</title>
    <meta name="description" content="Create your YogaFlow Pro account and start your personalized yoga journey today." />
    <RequiredB12HeadScripts />
  </head>

  <body>
    <Header currentPage="/signup" />

    <main class="min-h-[calc(100vh-200px)] bg-gradient-to-br from-secondary via-background to-accent/10 py-12 px-4 sm:px-6 lg:px-8">
      <div class="max-w-4xl mx-auto">
        <!-- Signup Card -->
        <div class="bg-background rounded-2xl shadow-2xl border border-border overflow-hidden">
          <!-- Header -->
          <div class="bg-gradient-to-r from-primary to-accent p-8 text-center">
            <div class="flex justify-center mb-4">
              <div class="w-16 h-16 bg-white rounded-xl flex items-center justify-center shadow-lg">
                <span class="text-primary font-bold text-2xl">ʎ</span>
              </div>
            </div>
            <h1 class="text-3xl font-heading font-bold text-white mb-2">Start Your Journey</h1>
            <p class="text-white/90">Join thousands of yogis on their wellness journey</p>
          </div>

          <!-- Form -->
          <div class="p-8">
            <form data-form-id="102ad2cb-4f1d-49da-a1a7-5ab5897c8266" class="space-y-6">
              <!-- Name Row -->
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                <div>
                  <label for="first_name" class="block text-sm font-semibold text-foreground mb-2">
                    First Name <span class="text-destructive">*</span>
                  </label>
                  <input
                    type="text"
                    id="first_name"
                    name="first_name"
                    required
                    placeholder="Aarav"
                    class="w-full px-4 py-3 rounded-lg border border-input bg-white text-foreground placeholder-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition-all"
                  />
                </div>
                <div>
                  <label for="last_name" class="block text-sm font-semibold text-foreground mb-2">
                    Last Name <span class="text-destructive">*</span>
                  </label>
                  <input
                    type="text"
                    id="last_name"
                    name="last_name"
                    required
                    placeholder="Sharma"
                    class="w-full px-4 py-3 rounded-lg border border-input bg-white text-foreground placeholder-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition-all"
                  />
                </div>
              </div>

              <!-- Email -->
              <div>
                <label for="email" class="block text-sm font-semibold text-foreground mb-2">
                  Email Address <span class="text-destructive">*</span>
                </label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  required
                  placeholder="you@example.com"
                  class="w-full px-4 py-3 rounded-lg border border-input bg-white text-foreground placeholder-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition-all"
                />
              </div>

              <!-- Password -->
              <div>
                <label for="password" class="block text-sm font-semibold text-foreground mb-2">
                  Password <span class="text-destructive">*</span>
                </label>
                <input
                  type="password"
                  id="password"
                  name="password"
                  required
                  placeholder="••••••••"
                  class="w-full px-4 py-3 rounded-lg border border-input bg-white text-foreground placeholder-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition-all"
                />
                <p class="text-xs text-muted-foreground mt-2">At least 8 characters with numbers and special characters</p>
              </div>

              <!-- Experience Level -->
              <div>
                <label for="experience_level" class="block text-sm font-semibold text-foreground mb-2">
                  Yoga Experience Level <span class="text-destructive">*</span>
                </label>
                <select
                  id="experience_level"
                  name="experience_level"
                  required
                  class="w-full px-4 py-3 rounded-lg border border-input bg-white text-foreground focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition-all"
                >
                  <option value="">Select your experience level</option>
                  <option value="Beginner">Beginner - Just starting out</option>
                  <option value="Intermediate">Intermediate - Practice regularly</option>
                  <option value="Advanced">Advanced - Experienced practitioner</option>
                </select>
              </div>

              <!-- Interests -->
              <div>
                <label class="block text-sm font-semibold text-foreground mb-3">
                  What are you interested in? <span class="text-destructive">*</span>
                </label>
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                  <label class="flex items-center p-3 border border-input rounded-lg hover:bg-secondary/30 cursor-pointer transition-colors">
                    <input type="checkbox" name="interests" value="Flexibility" class="rounded border-input" />
                    <span class="ml-3 font-medium text-foreground">Flexibility</span>
                  </label>
                  <label class="flex items-center p-3 border border-input rounded-lg hover:bg-secondary/30 cursor-pointer transition-colors">
                    <input type="checkbox" name="interests" value="Strength" class="rounded border-input" />
                    <span class="ml-3 font-medium text-foreground">Strength</span>
                  </label>
                  <label class="flex items-center p-3 border border-input rounded-lg hover:bg-secondary/30 cursor-pointer transition-colors">
                    <input type="checkbox" name="interests" value="Stress Relief" class="rounded border-input" />
                    <span class="ml-3 font-medium text-foreground">Stress Relief</span>
                  </label>
                  <label class="flex items-center p-3 border border-input rounded-lg hover:bg-secondary/30 cursor-pointer transition-colors">
                    <input type="checkbox" name="interests" value="Spiritual Growth" class="rounded border-input" />
                    <span class="ml-3 font-medium text-foreground">Spiritual Growth</span>
                  </label>
                  <label class="flex items-center p-3 border border-input rounded-lg hover:bg-secondary/30 cursor-pointer transition-colors">
                    <input type="checkbox" name="interests" value="Weight Loss" class="rounded border-input" />
                    <span class="ml-3 font-medium text-foreground">Weight Loss</span>
                  </label>
                </div>
              </div>

              <!-- Terms -->
              <label class="flex items-start p-4 bg-secondary/20 rounded-lg">
                <input type="checkbox" required class="rounded border-input mt-1" />
                <span class="ml-3 text-sm text-muted-foreground">
                  I agree to the
                  <a href="/privacy-policy" class="text-primary hover:text-accent font-semibold">Terms of Service</a>
                  and
                  <a href="/privacy-policy" class="text-primary hover:text-accent font-semibold">Privacy Policy</a>
                </span>
              </label>

              <!-- Signup Button -->
              <button
                type="submit"
                class="w-full py-3 bg-gradient-to-r from-primary to-accent text-white font-semibold rounded-lg hover:shadow-lg transform hover:scale-105 transition-all duration-200"
              >
                Create Account
              </button>
            </form>

            <div id="b12-form-done-102ad2cb-4f1d-49da-a1a7-5ab5897c8266" class="hidden bg-green-50 border border-green-200 text-green-800 px-4 py-3 rounded-lg mt-4">
              Welcome to YogaFlow Pro! Your account has been created successfully. Check your email to confirm your account.
            </div>

            <div id="b12-form-error-102ad2cb-4f1d-49da-a1a7-5ab5897c8266" class="hidden bg-red-50 border border-red-200 text-red-800 px-4 py-3 rounded-lg mt-4">
              There was an error creating your account. Please try again.
            </div>

            <!-- Divider -->
            <div class="flex items-center gap-4 my-6">
              <div class="flex-1 h-px bg-border"></div>
              <span class="text-sm text-muted-foreground">or</span>
              <div class="flex-1 h-px bg-border"></div>
            </div>

            <!-- Login Link -->
            <p class="text-center text-sm text-muted-foreground">
              Already have an account?
              <a href="/login" class="text-primary hover:text-accent font-semibold transition-colors">
                Sign in here
              </a>
            </p>
          </div>
        </div>

        <!-- Benefits Section -->
        <div class="mt-12 grid grid-cols-1 md:grid-cols-3 gap-8">
          <div class="text-center">
            <div class="w-12 h-12 rounded-full bg-primary/10 flex items-center justify-center mx-auto mb-4">
              <svg class="w-6 h-6 text-primary" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
              </svg>
            </div>
            <h3 class="font-heading font-semibold text-foreground mb-2">Personalized Classes</h3>
            <p class="text-sm text-muted-foreground">Get AI-powered recommendations tailored to your goals and experience level</p>
          </div>
          <div class="text-center">
            <div class="w-12 h-12 rounded-full bg-primary/10 flex items-center justify-center mx-auto mb-4">
              <svg class="w-6 h-6 text-primary" fill="currentColor" viewBox="0 0 24 24">
                <path d="M17 10.5V7c0-.55-.45-1-1-1H4c-.55 0-1 .45-1 1v10c0 .55.45 1 1 1h12c.55 0 1-.45 1-1v-3.5l4 4v-11l-4 4z"/>
              </svg>
            </div>
            <h3 class="font-heading font-semibold text-foreground mb-2">Live & On-Demand</h3>
            <p class="text-sm text-muted-foreground">Access hundreds of classes live or anytime with our flexible scheduling</p>
          </div>
          <div class="text-center">
            <div class="w-12 h-12 rounded-full bg-primary/10 flex items-center justify-center mx-auto mb-4">
              <svg class="w-6 h-6 text-primary" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm3.5-9c.83 0 1.5-.67 1.5-1.5S16.33 8 15.5 8 14 8.67 14 9.5s.67 1.5 1.5 1.5zm-7 0c.83 0 1.5-.67 1.5-1.5S9.33 8 8.5 8 7 8.67 7 9.5 7.67 11 8.5 11zm3.5 6.5c2.33 0 4.31-1.46 5.11-3.5H6.89c.8 2.04 2.78 3.5 5.11 3.5z"/>
              </svg>
            </div>
            <h3 class="font-heading font-semibold text-foreground mb-2">Expert Instructors</h3>
            <p class="text-sm text-muted-foreground">Learn from certified yoga teachers with years of experience</p>
          </div>
        </div>
      </div>
    </main>

    <Footer />
    <RequiredB12FooterScripts />
  </body>
</html>
